generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// One row per user per calendar day — wearable metrics only.
// All metric fields are nullable; they fill in as the watch calibrates.
model DailyHealthSnapshot {
  id String @id @default(cuid())

  userId String // Google sub (session.user.id)
  date   String // YYYY-MM-DD local date

  // Sleep
  sleepMinutes    Int?   // total sleep duration
  sleepEfficiency Float? // 0–100 %
  sleepDeepMin    Int?   // deep stage minutes
  sleepRemMin     Int?   // REM stage minutes
  sleepLightMin   Int?   // light stage minutes

  // Cardiac
  restingHr Float? // resting HR bpm
  hrv       Float? // daily HRV ms

  // Activity
  steps         Int? // step count
  activeMinutes Int? // active minutes

  syncedAt DateTime @default(now()) @updatedAt

  @@unique([userId, date])
  @@index([userId])
}

// Phase 3B: workout sessions synced from Google Health API exercise endpoint.
model WorkoutSession {
  id     String @id @default(cuid())
  userId String

  startTime String // ISO datetime string
  endTime   String // ISO datetime string
  date      String // YYYY-MM-DD of startTime

  typeLabel       String  // human-readable, e.g. "Strength training"
  typeRaw         String  // raw API value, e.g. "STRENGTH_TRAINING"
  durationMinutes Int
  source          String? // e.g. "FITBIT"

  syncedAt DateTime @default(now()) @updatedAt

  @@unique([userId, startTime])
  @@index([userId, date])
}

// Phase 2C: night reflection — was today's recommendation accurate?
model Reflection {
  id     String @id @default(cuid())
  userId String
  date   String // YYYY-MM-DD

  // Was the day type recommendation accurate?
  accuracy String // "yes" | "somewhat" | "no"
  // How did training/work actually go?
  outcome  String // "great" | "good" | "skipped" | "rest"
  // Optional free-text note
  note     String?

  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
}

// Phase 2B: morning check-in — defined now so DB is ready.
model CheckIn {
  id     String @id @default(cuid())
  userId String
  date   String // YYYY-MM-DD

  energyLevel  Int // 1–10
  stressLevel  Int // 1–10 (higher = more stressed)
  sleepQuality Int // 1–10 (subjective)
  motivation   Int // 1–10

  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
}
