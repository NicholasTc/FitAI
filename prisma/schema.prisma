generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// One row per user per calendar day — wearable metrics only.
// All metric fields are nullable; they fill in as the watch calibrates.
model DailyHealthSnapshot {
  id String @id @default(cuid())

  userId String // Google sub (session.user.id)
  date   String // YYYY-MM-DD local date

  // Sleep
  sleepMinutes    Int?   // total sleep duration
  sleepEfficiency Float? // 0–100 %
  sleepDeepMin    Int?   // deep stage minutes
  sleepRemMin     Int?   // REM stage minutes
  sleepLightMin   Int?   // light stage minutes

  // Cardiac
  restingHr Float? // resting HR bpm
  hrv       Float? // daily HRV ms

  // Activity
  steps         Int?   // step count
  activeMinutes Int?   // active minutes
  totalCalories Float? // total kcal burned (resting + active)

  syncedAt DateTime @default(now()) @updatedAt

  @@unique([userId, date])
  @@index([userId])
}

// Workout sessions — manual logs (primary) or synced from API (future).
// Manual logs use isManual=true; startTime/endTime/typeRaw are optional for manual.
model WorkoutSession {
  id     String @id @default(cuid())
  userId String

  date            String  // YYYY-MM-DD
  typeLabel       String  // human-readable: "Strength" | "Cardio" | "Mixed" | "Sport" | "Other"
  durationMinutes Int     // session duration in minutes

  // Manual log fields (Phase B)
  isManual        Boolean @default(false)
  rpe             Int?    // 1–10 Rate of Perceived Exertion (Foster 2001)
  sessionLoad     Int?    // computed: rpe × durationMinutes (arbitrary units)

  // API sync fields (optional for manual logs)
  startTime String? // ISO datetime string
  endTime   String? // ISO datetime string
  typeRaw   String? // raw API value
  source    String? // "FITBIT" | "MANUAL"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
}

// Phase 2C: night reflection — was today's recommendation accurate?
model Reflection {
  id     String @id @default(cuid())
  userId String
  date   String // YYYY-MM-DD

  // Was the day type recommendation accurate?
  accuracy String // "yes" | "somewhat" | "no"
  // How did training/work actually go?
  outcome  String // "great" | "good" | "skipped" | "rest"
  // Optional free-text note
  note     String?

  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
}

// User-configurable preferences — one row per user.
model UserSettings {
  id     String @id @default(cuid())
  userId String @unique

  wakeTime        String @default("07:00") // HH:MM 24h
  sleepTargetTime String @default("23:00") // HH:MM 24h (target bedtime, used as upper clamp)
  deepWorkLabel   String @default("Deep work")
  lightWorkLabel  String @default("Admin / Comms")

  // Phase A: biometric profile — enables BMR computation + age/sex-adjusted HRV thresholds.
  // All nullable — profile is optional; scoring degrades gracefully without it.
  age      Int?    // years (10–99)
  sex      String? // "male" | "female"
  heightCm Float?  // centimetres (100–250)
  weightKg Float?  // kilograms (20–300)

  updatedAt DateTime @updatedAt
}

// Phase 0: score audit — one row per user per day.
// Records the score, breakdown, and scoring method so accuracy improvements
// can be measured over historical days rather than guessed at.
model ScoreAudit {
  id     String @id @default(cuid())
  userId String
  date   String // YYYY-MM-DD

  score            Float
  dayType          String  // "push" | "maintain" | "recover"
  method           String  // "legacy" | "z-score" | "load" | "z-score+load"
  dataCompleteness Float   // 0–1 fraction of key signals that are real data
  breakdown        Json    // ScoreBreakdown object

  updatedAt DateTime @default(now()) @updatedAt

  @@unique([userId, date])
  @@index([userId])
}

// Phase 2B: morning check-in — defined now so DB is ready.
model CheckIn {
  id     String @id @default(cuid())
  userId String
  date   String // YYYY-MM-DD

  energyLevel  Int // 1–10
  stressLevel  Int // 1–10 (higher = more stressed)
  sleepQuality Int // 1–10 (subjective)
  motivation   Int // 1–10

  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
}
